{
  "description": "AuthApi-specific deep dive: authentication operations, Cognito/JWKS dependency health, and Node.js runtime internals. Companion to the generic Application Analytics dashboard (golden signals, infra, DB).",
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 3,
      "title": "🔐 Layer 5 — Auth Operations",
      "type": "row",
      "panels": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 15,
                "gradientMode": "opacity",
                "showPoints": "never",
                "stacking": {
                  "mode": "normal"
                }
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*true.*"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "green"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*false.*"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "red"
                    }
                  }
                ]
              }
            ]
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 1
          },
          "id": 30,
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum by(success) (rate(auth_attempts_total{job=\"authapi\"}[$__rate_interval]))",
              "legendFormat": "success={{success}}",
              "refId": "A"
            }
          ],
          "title": "Authentication Attempts — Success vs Failure",
          "type": "timeseries",
          "description": "**What it measures:** Rate of authentication attempts (user login / token exchange) split by success/failure.\n\nThis is the front door of AuthApi. A spike in failures could indicate brute-force attempts, credential issues, or Cognito outages.",
          "interval": "1m"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 15,
                "gradientMode": "opacity",
                "showPoints": "never",
                "stacking": {
                  "mode": "normal"
                }
              }
            },
            "overrides": [
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*true.*"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "green"
                    }
                  }
                ]
              },
              {
                "matcher": {
                  "id": "byRegexp",
                  "options": ".*false.*"
                },
                "properties": [
                  {
                    "id": "color",
                    "value": {
                      "mode": "fixed",
                      "fixedColor": "red"
                    }
                  }
                ]
              }
            ]
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 1
          },
          "id": 31,
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum by(valid) (rate(token_validations_total{job=\"authapi\"}[$__rate_interval]))",
              "legendFormat": "valid={{valid}}",
              "refId": "A"
            }
          ],
          "title": "Token Validations — Valid vs Invalid",
          "type": "timeseries",
          "description": "**What it measures:** Rate of JWT token validation calls, split by valid/invalid.\n\nEvery downstream service call to `/api/auth/validate` is counted here. Invalid tokens may indicate expired sessions, tampered tokens, or clock skew.",
          "interval": "1m"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 15,
                "gradientMode": "opacity",
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 9
          },
          "id": 32,
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum by(operation, reason) (rate(auth_failures_total{job=\"authapi\"}[$__rate_interval]))",
              "legendFormat": "{{operation}} — {{reason}}",
              "refId": "A"
            }
          ],
          "title": "Auth Failure Breakdown (by operation & reason)",
          "type": "timeseries",
          "description": "**What it measures:** Auth failures broken down by operation (token, validate) and specific failure reason.\n\nThis panel shows *why* authentication is failing — invalid credentials, expired tokens, Cognito errors, etc. Requires the `auth_failures_total` counter to have data.",
          "interval": "1m"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 15,
                "gradientMode": "opacity",
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 9
          },
          "id": 33,
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum by(reason) (rate(auth_token_validation_failures_total{job=\"authapi\"}[$__rate_interval]))",
              "legendFormat": "{{reason}}",
              "refId": "A"
            }
          ],
          "title": "Token Validation Failures (by reason)",
          "type": "timeseries",
          "description": "**What it measures:** Why token validations are failing — expired, malformed, invalid signature, wrong audience, etc.\n\nRequires the `auth_token_validation_failures_total` counter to have data.",
          "interval": "1m"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "gradientMode": "opacity",
                "showPoints": "never"
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 0.5
                  },
                  {
                    "color": "red",
                    "value": 2
                  }
                ]
              }
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 24,
            "x": 0,
            "y": 17
          },
          "id": 34,
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "histogram_quantile(0.95, sum by(le, route) (rate(http_request_duration_seconds_bucket{job=\"authapi\"}[$__rate_interval])))",
              "legendFormat": "p95 {{route}}",
              "refId": "A"
            },
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "histogram_quantile(0.50, sum by(le, route) (rate(http_request_duration_seconds_bucket{job=\"authapi\"}[$__rate_interval])))",
              "legendFormat": "p50 {{route}}",
              "refId": "B"
            }
          ],
          "title": "Latency per Route — p50 / p95",
          "type": "timeseries",
          "description": "**What it measures:** Request latency broken down per API route.\n\n`/api/auth/token` is expected to be slower (involves Cognito SDK calls + OAuth2 token exchange).\n`/api/auth/validate` should be fast (local JWKS key lookup + JWT verification).",
          "interval": "1m"
        }
      ]
    },
    {
      "collapsed": true,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "id": 4,
      "title": "🔗 Layer 6 — Dependency Health",
      "type": "row",
      "panels": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "reqpm",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 15,
                "gradientMode": "opacity",
                "showPoints": "never",
                "stacking": {
                  "mode": "normal"
                }
              }
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 26
          },
          "id": 40,
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "(sum by(dependency, operation) (rate(auth_dependency_requests_total{job=\"authapi\"}[$__rate_interval]))) * 60",
              "legendFormat": "{{dependency}} / {{operation}}",
              "refId": "A"
            }
          ],
          "title": "Dependency Request Rate (RPM)",
          "type": "timeseries",
          "description": "**What it measures:** Rate of outbound calls to external dependencies.\n\n**cognito / DescribeUserPool:** Called during token exchange to validate the user pool.\n**cognito / oauth2_token:** The actual OAuth2 token request to Cognito.\n**jwks / getSigningKey:** JWKS key fetch for JWT signature verification.",
          "interval": "1m"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "s",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 10,
                "gradientMode": "opacity",
                "showPoints": "never"
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "green",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 0.5
                  },
                  {
                    "color": "red",
                    "value": 2
                  }
                ]
              }
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 26
          },
          "id": 41,
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "histogram_quantile(0.95, sum by(le, dependency, operation) (rate(auth_dependency_request_duration_seconds_bucket{job=\"authapi\"}[$__rate_interval])))",
              "legendFormat": "p95 {{dependency}} / {{operation}}",
              "refId": "A"
            },
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "histogram_quantile(0.50, sum by(le, dependency, operation) (rate(auth_dependency_request_duration_seconds_bucket{job=\"authapi\"}[$__rate_interval])))",
              "legendFormat": "p50 {{dependency}} / {{operation}}",
              "refId": "B"
            }
          ],
          "title": "Dependency Latency — p50 / p95",
          "type": "timeseries",
          "description": "**What it measures:** How long each dependency call takes.\n\nCognito SDK calls are typically 100-500ms. JWKS key lookups should be <50ms (cached). A spike here directly impacts AuthApi response times.",
          "interval": "1m"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "short",
              "color": {
                "mode": "palette-classic"
              },
              "custom": {
                "lineWidth": 2,
                "fillOpacity": 15,
                "gradientMode": "opacity",
                "showPoints": "never"
              }
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 0,
            "y": 34
          },
          "id": 42,
          "options": {
            "tooltip": {
              "mode": "multi",
              "sort": "desc"
            },
            "legend": {
              "displayMode": "list",
              "placement": "bottom"
            }
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum by(dependency, operation) (rate(auth_dependency_requests_total{job=\"authapi\", outcome=\"failure\"}[$__rate_interval]))",
              "legendFormat": "FAIL: {{dependency}} / {{operation}}",
              "refId": "A"
            }
          ],
          "title": "Dependency Failures",
          "type": "timeseries",
          "description": "**What it measures:** Rate of failed calls to external dependencies.\n\nAny non-zero value here is concerning. Cognito failures = users can't authenticate. JWKS failures = tokens can't be validated.",
          "interval": "1m"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "fieldConfig": {
            "defaults": {
              "unit": "percentunit",
              "min": 0,
              "max": 1,
              "color": {
                "mode": "thresholds"
              },
              "thresholds": {
                "mode": "absolute",
                "steps": [
                  {
                    "color": "red",
                    "value": null
                  },
                  {
                    "color": "yellow",
                    "value": 0.95
                  },
                  {
                    "color": "green",
                    "value": 0.99
                  }
                ]
              }
            },
            "overrides": []
          },
          "gridPos": {
            "h": 8,
            "w": 12,
            "x": 12,
            "y": 34
          },
          "id": 43,
          "options": {
            "reduceOptions": {
              "calcs": [
                "lastNotNull"
              ],
              "fields": "",
              "values": false
            },
            "orientation": "horizontal",
            "displayMode": "gradient",
            "showUnfilled": true,
            "valueMode": "color",
            "text": {
              "titleSize": 13,
              "valueSize": 18
            },
            "minVizWidth": 0,
            "minVizHeight": 10
          },
          "targets": [
            {
              "datasource": {
                "type": "prometheus",
                "uid": "prometheus"
              },
              "expr": "sum by(dependency) (rate(auth_dependency_requests_total{job=\"authapi\", outcome=\"success\"}[$__rate_interval])) / sum by(dependency) (rate(auth_dependency_requests_total{job=\"authapi\"}[$__rate_interval]))",
              "legendFormat": "{{dependency}}",
              "refId": "A",
              "instant": true
            }
          ],
          "title": "Dependency Success Rate",
          "type": "bargauge",
          "description": "**What it measures:** Success ratio for each external dependency.\n\nTargets: >99% for all dependencies. Below 95% is critical — the auth service is effectively degraded."
        }
      ]
    },
    {
      "collapsed": true,
