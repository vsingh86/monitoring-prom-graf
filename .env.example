# Copy to .env before starting the database containers.

# App Monitoring - Grafana, Prometheus, and Alert Relay

# Grafana config
GF_SERVER_DOMAIN=localhost
GF_SERVER_ROOT_URL=http://localhost:3001/
GF_SERVER_SERVE_FROM_SUB_PATH=false
GF_AUTH_ANONYMOUS_ENABLED=true
GRAFANA_ADMIN_PASSWORD=byteme
GRAFANA_READONLY_LINUX_PASSWORD=byteme
GRAFANA_READONLY_WINDOWS_PASSWORD=byteme

# Prometheus
PROMETHEUS_SERVER=http://localhost:9090  
PROMETHEUS_PASSWORD=byteme

# Alert relay - Lambda IAM
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
ALERT_WEBHOOK_PASSCODE=byteme

# Applications Creds and Secrets

# HIMS
HIMS_WEB_DEV_METRICS_TOKEN=byteme
HIMS_WEBSERVICE_DEV_METRICS_TOKEN=byteme
HIMS_DB_DEV_CONNECTION_STRING=

# HRIS AUTH API METRICS TOKEN
HRIS_AUTH_API_METRICS_TOKEN=byteme

# HRIS CARD API DEV METRICS TOKEN
HRIS_CARD_API_DEV_METRICS_TOKEN=byteme


# Copy to .env AT THE REPO ROOT (same directory as docker-compose.yml) and
# fill in real values. Never commit .env -- docker-compose.yml's db-exporter
# service reads these via Compose's automatic root .env auto-load, which is
# optional (missing .env just means empty passwords, not a startup failure
# for the rest of the stack -- see docker-compose.yml's db-exporter comment).
#
# Adding a new database: add its ${VAR_NAME} to db-exporter/config.yaml, add
# the real value here, and add a matching line to docker-compose.yml's
# db-exporter "environment:" block.
AUTHAPI_POSTGRES_PASSWORD=
MYAPP_MYSQL_PASSWORD=
MYAPP_SQLSERVER_PASSWORD=
MYAPP_ORACLE_PASSWORD=